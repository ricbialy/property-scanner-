# Property Scan — local development environment (safe placeholders only).
# Copy to .env and adjust. Never commit real credentials.

APP_ENV=development
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# PostgreSQL (compose.yaml default, or scripts/local-postgres.sh embedded cluster)
DATABASE_URL=postgres://propertyscan:propertyscan@localhost:5432/propertyscan

# Authentication.
# AUTH_MODE=dev accepts "Bearer dev_<clerkUserId>" tokens for local development/tests.
# AUTH_MODE=clerk verifies Clerk-issued JWTs against CLERK_JWT_ISSUER JWKS.
AUTH_MODE=dev
CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_JWT_ISSUER=https://example-placeholder.clerk.accounts.dev

# Object storage.
# STORAGE_DRIVER=fs stores objects under .local/objects (local development only).
# STORAGE_DRIVER=s3 uses the S3-compatible settings below (MinIO in compose.yaml).
STORAGE_DRIVER=fs
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=propertyscan-dev
S3_ACCESS_KEY_ID=propertyscan
S3_SECRET_ACCESS_KEY=propertyscan-dev-secret
UPLOAD_MAX_BYTES=524288000

# Webhooks and integrations — external delivery is disabled by default locally.
WEBHOOK_MASTER_ENCRYPTION_KEY=dev-only-not-a-real-key-0000000000000000
DISABLE_EXTERNAL_WEBHOOKS=true

# Observability (optional locally)
OTEL_EXPORTER_OTLP_ENDPOINT=

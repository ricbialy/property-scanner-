{
  "name": "@propertyscan/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsc -p tsconfig.json --watch & node --watch dist/main.js"
  },
  "dependencies": {
    "@propertyscan/config": "workspace:*",
    "@propertyscan/contracts": "workspace:*",
    "@propertyscan/database": "workspace:*",
    "@propertyscan/geometry": "workspace:*",
    "@propertyscan/integration-studiokl": "workspace:*",
    "@propertyscan/observability": "workspace:*",
    "@propertyscan/storage": "workspace:*",
    "fflate": "^0.8.2",
    "pg": "^8.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@propertyscan/eslint-config": "workspace:*",
    "@propertyscan/roomplan-fixtures": "workspace:*",
    "@propertyscan/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}

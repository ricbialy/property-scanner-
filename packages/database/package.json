{
  "name": "@propertyscan/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "node dist/cli/migrate.js",
    "seed": "node dist/cli/seed.js"
  },
  "dependencies": {
    "@propertyscan/contracts": "workspace:*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@propertyscan/eslint-config": "workspace:*",
    "@propertyscan/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.15.0",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
